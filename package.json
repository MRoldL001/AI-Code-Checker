{
  "name": "simple-ai-code-checker",
  "displayName": "Simple AI Code Checker",
  "description": "Smart Code Quality Checker: AI Scoring & Colorful Status Bar.",
  "version": "1.0.0",
  "publisher": "MRoldL001",
  "icon": "ai-code-checker.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/MRoldL001/AI-Code-Checker.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:javascript",
    "onLanguage:typescript",
    "onLanguage:javascriptreact",
    "onLanguage:typescriptreact",
    "onLanguage:python",
    "onLanguage:html",
    "onLanguage:css"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeChecker.checkCodeQuality",
        "title": "д»Јз ҒжЈҖжҹҘеҷЁпјҡжЈҖжҹҘд»Јз ҒиҙЁйҮ?"
      }
    ],
    "configuration": {
      "title": "д»Јз ҒжЈҖжҹҘеҷЁ",
      "properties": {
        "codeChecker.aiProvider": {
          "type": "string",
          "enum": [
            "local",
            "remote"
          ],
          "default": "local",
          "description": "йҖүжӢ©AIжңҚеҠЎжҸҗдҫӣе•ҶпјҲlocal=жң¬ең°Ollama, remote=иҝңзЁӢAPIпј?"
        },
        "codeChecker.local.model": {
          "type": "string",
          "default": "llama2",
          "description": "жң¬ең°OllamaжЁЎеһӢеҗҚз§°"
        },
        "codeChecker.remote.endpoint": {
          "type": "string",
          "default": "",
          "description": "иҝңзЁӢAPIең°еқҖпјҲж”ҜжҢҒOpenAIе…је®№ж јејҸпј?"
        },
        "codeChecker.remote.apiKey": {
          "type": "string",
          "default": "",
          "description": "иҝңзЁӢAPIеҜҶй’ҘпјҲеҸҜйҖүпјү"
        },
        "codeChecker.remote.model": {
          "type": "string",
          "default": "",
          "description": "иҝңзЁӢAPIжЁЎеһӢеҗҚз§°"
        },
        "codeChecker.autoUpdate": {
          "type": "boolean",
          "default": true,
          "description": "еҗҜз”Ёд»Јз ҒиҙЁйҮҸеҲҶж•°иҮӘеҠЁжӣҙж–°"
        },
        "codeChecker.updateDebounceMs": {
          "type": "number",
          "default": 2000,
          "description": "иҮӘеҠЁжӣҙж–°зҡ„йҳІжҠ–ж—¶й—ҙпјҲжҜ«з§’пј?"
        },
        "codeChecker.statusBarPosition": {
          "type": "string",
          "enum": [
            "left",
            "right"
          ],
          "default": "right",
          "description": "зҠ¶жҖҒж ҸйЎ№дҪҚзҪ?"
        },
        "codeChecker.systemPrompt": {
          "type": "string",
          "default": "You are a code quality evaluator. Score the code 0-100:\n- 90-100: Excellent, production-ready code\n- 80-89: Good quality, minor issues\n- 70-79: Acceptable, some problems\n- 60-69: Just acceptable, needs improvement\n- 0-59: Poor, serious issues\nIf the code runs without errors and is functional, give at least 60 points.\nIMPORTANT: Return a number like 73, 81, 67, 88, 62, 77, etc. Avoid always returning multiples of 5. Return ONLY the number.\n\nAdditional reminders (IMPORTANT!):\n1. Be generous with scores! Do not be stingy with points.\n2. Evaluate from the perspective of an ordinary coder, not a professional developer.\n3. Do not hesitate to give high scores including 90-100.\n4. Most code written by ordinary developers deserves encouragement.",
          "description": "AIд»Јз ҒиҙЁйҮҸжЈҖжҹҘзҡ„зі»з»ҹжҸҗзӨәиҜ?"
        }
      }
    },
    "keybindings": [
      {
        "command": "codeChecker.checkCodeQuality",
        "key": "ctrl+alt+e",
        "mac": "cmd+alt+e",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/node": "^20.x",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.3",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vscode/test-cli": "^0.0.4",
    "@vscode/test-electron": "^2.3.9"
  },
  "dependencies": {
    "axios": "^1.6.7"
  }
}
